## PARTE 2 — Frontend: Integração Completa

### 2A — Tipos

#### [MODIFY] [types.ts](file:///c:/xampp/htdocs/apontamento/src/types.ts)

Adicionar interfaces alinhadas com o backend:

```typescript
export interface LoteAPI {
  id: string;
  status: 'ABERTO' | 'FECHADO';
  ordem_id: string;
  ordem_item_id: number;
  produto_id: string;
  indice_ordem: number;
  peso_bruto: number;
  tara: number;
  peso_liquido: number;
  total_peso_bom: number;
  total_peso_scrap: number;
  qtd_rolos_total: number;
  qtd_rolos_bom: number;
  qtd_rolos_scrap: number;
  data_fechamento: string | null;
  criado_em: string;
}

export interface ApontarRoloResponse {
  rolo: { uid: string; lote_id: string; item_id: number; peso_liquido: number; is_scrap: boolean; criado_em: string };
  lote_resumo: Pick<LoteAPI, 'id'|'status'|'total_peso_bom'|'total_peso_scrap'|'qtd_rolos_total'|'qtd_rolos_bom'|'qtd_rolos_scrap'> & { total_peso: number };
  progresso_meta: { item_id: number; indice_ordem: number; produto_id: string; meta_qtd_rolos: number; apontados_qtd_rolos_bom: number; faltantes: number };
}

export interface ScannerResponse {
  ordem: { id: string; bobina_id: string; status: string };
  item: { id: number; produto_id: string; processo: string; indice_ordem: number; largura_mm: number; peso_teorico: number; qtd_rolos: number };
  scanner: { codigo_injetado: string; tipo: 'UID' | 'SKU' };
}
```

### 2B — Serviço de API

#### [NEW] [coletorApi.ts](file:///c:/xampp/htdocs/apontamento/src/services/coletorApi.ts)

```typescript
export const coletorApi = {
  // Scanner
  scan: (codigo: string)                     => apiFetch<ScannerResponse>(`/ordens-servico/ativa/itens/${encodeURIComponent(codigo)}`),

  // Lotes
  getLoteAtivo: ()                           => apiFetch<LoteAPI>('/lotes/ativo').catch(() => null),
  getLotesFechados: (ordemId?: string)       => apiFetch<LoteAPI[]>(`/lotes?status=FECHADO${ordemId ? `&ordem_id=${ordemId}` : ''}`),
  abrirLote: (ordemItemId: number)           => apiFetch<LoteAPI>('/lotes', { method: 'POST', data: { ordem_item_id: ordemItemId } }),
  fecharLote: (id: string)                   => apiFetch<LoteAPI>(`/lotes/${id}/fechar`, { method: 'PATCH' }),

  // Rolos
  apontar: (uid: string, pesoLiquido: number, isScrap = false, loteId?: string) =>
    apiFetch<ApontarRoloResponse>('/rolos', { method: 'POST', data: { uid_codigo: uid, peso_liquido: pesoLiquido, is_scrap: isScrap, ...(loteId ? { lote_id: loteId } : {}) } }),
  estornar: (uid: string)                    => apiFetch<void>(`/rolos/${uid}`, { method: 'DELETE' }),
};
```

### 2C — [App.tsx](file:///c:/xampp/htdocs/apontamento/src/App.tsx) — Substituir handlers e remover localStorage

#### [MODIFY] [App.tsx](file:///c:/xampp/htdocs/apontamento/src/App.tsx)

**Estado novo:**
```typescript
const [loteAtivo, setLoteAtivo] = useState<LoteAPI | null>(null);
const [historicoLotes, setHistoricoLotes] = useState<LoteAPI[]>([]);
// Remover: localStorage.getItem('historicoLotes')
```

**Efeito: carregar ao montar com OS ativa:**
```typescript
useEffect(() => {
  if (!ordemAtivaId) return;
  coletorApi.getLoteAtivo().then(setLoteAtivo);
  coletorApi.getLotesFechados(ordemAtivaId).then(setHistoricoLotes);
}, [ordemAtivaId]);
```

**Handlers reescritos:**

| Handler | Antes | Depois |
|---|---|---|
| [handleAutoScan](file:///c:/xampp/htdocs/apontamento/src/App.tsx#177-211) | resolve local | `coletorApi.scan()` |
| `handleAbrirLote` | cria objeto local | `coletorApi.abrirLote()` → `setLoteAtivo` |
| [handleAddRolo](file:///c:/xampp/htdocs/apontamento/src/App.tsx#98-136) | push em array | `coletorApi.apontar()` → atualiza totais via `lote_resumo` |
| [handleRemoveRolo](file:///c:/xampp/htdocs/apontamento/src/App.tsx#137-150) | filter local | `coletorApi.estornar()` → refetch totais |
| [handleCloseLote](file:///c:/xampp/htdocs/apontamento/src/App.tsx#151-163) | move p/ histórico | `coletorApi.fecharLote()` → `setLoteAtivo(null)` + append `historicoLotes` |

**Remover:**
```typescript
// Remover este useEffect:
useEffect(() => {
  localStorage.setItem('historicoLotes', JSON.stringify(appState.historicoLotes));
}, [appState.historicoLotes]);
```

